# Enable Powerlevel10k instant prompt
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
plugins=(git zsh-autosuggestions zsh-syntax-highlighting zsh-interactive-cd)
source $ZSH/oh-my-zsh.sh

# =============================================================================
# PATH
# =============================================================================
export PATH="$HOME/.npm-global/bin:$PATH"
export PATH="$HOME/.pub-cache/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"
export PATH="$HOME/Library/Python/3.9/bin:$PATH"
export PATH="$HOME/.local/bin:$PATH"

# Dotfiles CLI (if repo exists locally)
[[ -d "$HOME/dev/dotfiles/bin" ]] && export PATH="$HOME/dev/dotfiles/bin:$PATH"

{{- if eq .chezmoi.os "darwin" }}
# macOS Homebrew
export PATH="/opt/homebrew/opt/ruby/bin:$PATH"
export PATH="/opt/homebrew/opt/curl/bin:$PATH"
export PATH="/Users/tristan/.antigravity/antigravity/bin:$PATH"
if [[ -f /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi
{{- end }}

# =============================================================================
# Modern CLI Replacements
# =============================================================================
alias ls='eza --icons --group-directories-first'
alias ll='eza -lgh --icons --git --group-directories-first'
alias la='eza -lagh --icons --git --group-directories-first'
alias lt='eza --tree --level=2 --icons'
alias cat='bat --paging=never'
alias preview='bat'
alias df='duf'
alias top='btm'
alias find='fd'
alias grep='rg'
alias help='tldr'

# =============================================================================
# Intelligent Tools
# =============================================================================
eval "$(zoxide init zsh)"
alias cd='z'
eval $(thefuck --alias)
eval $(thefuck --alias fuck)
source <(fzf --zsh)

# =============================================================================
# Web / Server Aliases (macOS Homebrew services)
# =============================================================================
{{- if eq .chezmoi.os "darwin" }}
alias apache-start="sudo /opt/homebrew/bin/httpd -k start"
alias apache-restart="sudo /opt/homebrew/bin/httpd -k restart"
alias apache-stop="sudo /opt/homebrew/bin/httpd -k stop"
alias php-start="brew services start php"
alias php-restart="brew services restart php"
alias php-stop="brew services stop php"
alias sql-start="brew services start mysql"
alias sql-restart="brew services restart mysql"
alias sql-stop="brew services stop mysql"
alias web-start="brew services start php && brew services start mysql && sudo /opt/homebrew/bin/httpd -k start"
alias web-stop="brew services stop php && brew services stop mysql && sudo /opt/homebrew/bin/httpd -k stop"
alias web-restart="brew services restart php && brew services restart mysql && sudo /opt/homebrew/bin/httpd -k restart"
{{- end }}

# =============================================================================
# Development Helpers
# =============================================================================
laravelnew() {
  if [ -z "$1" ]; then
    echo "❌ Usage: laravelnew project_name"
    return 1
  fi
  composer create-project laravel/laravel "$1"
}

ideh() {
  if [ ! -f "artisan" ]; then
    echo "❌ No artisan file found. Are you in a Laravel project root?"
    return 1
  fi
  if ! grep -q '"barryvdh/laravel-ide-helper"' composer.json 2>/dev/null; then
    composer require --dev barryvdh/laravel-ide-helper
  fi
  php artisan ide-helper:generate
  php artisan ide-helper:models -R
  php artisan ide-helper:meta
  echo "✅ Done! Restart Neovim to pick up the new stubs."
}

pyRun() {
  if [ -z "$1" ]; then
    echo "❌ Usage: pyRun <file.py>"
    return 1
  fi
  python3 "$1"
}

mvPath() {
  if [ -z "$1" ]; then
    echo "❌ Usage: mvPath <file>"
    return 1
  fi
  mv "$1" "$HOME/.local/bin/"
}

# =============================================================================
# Advanced Shortcuts
# =============================================================================
fo() {
  local file
  file=$(fd --type f | fzf) && [ -n "$file" ] && ${EDITOR:-nvim} "$file"
}
zle -N fo_widget fo
bindkey '^O' fo_widget

rgp() {
  rg --line-number --column --color=always "$1" | \
  fzf --ansi --delimiter : --preview 'bat --style=numbers --color=always --highlight-line {2} {1}'
}

toolhelp() {
  printf '\e[1;36m┏━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┓\n┃ \e[1;33m🚀 MY TERMINAL TOOLKIT\e[1;36m                              ┃\n┗━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━┛\e[0m\n'
  cat << EOF | bat --language=yaml --style=grid --color=always
Navigation:
  cd: "z [query] (zoxide)"
  ls/ll: "List files with icons/git (eza)"
Search:
  find: "Find files by name (fd)"
  grep: "Search text in files (ripgrep)"
  fo: "Search & Open in Neovim (Ctrl+O)"
System:
  top: "CPU/RAM Monitor (bottom)"
  df: "Disk usage dashboard (duf)"
Help:
  help: "Simplified man pages (tldr)"
  fuck: "Fix previous typo command"
Config:
  zconf: "Edit .zshrc"
  zreload: "Apply changes"
EOF
}

# =============================================================================
# Config Shortcuts
# =============================================================================
alias sc-zrc="source ~/.zshrc"
alias v-zrc="nvim ~/.zshrc"
alias v="nvim ."

# =============================================================================
# Powerlevel10k
# =============================================================================
{{- if eq .chezmoi.os "darwin" }}
source /opt/homebrew/share/powerlevel10k/powerlevel10k.zsh-theme
{{- else }}
source ${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/themes/powerlevel10k/powerlevel10k.zsh-theme
