{{- $email := "" -}}
{{- $name := "" -}}
{{- $bitwarden := false -}}

{{- if hasKey . "email" -}}
{{-   $email = .email -}}
{{- else -}}
{{-   $email = promptString "email" -}}
{{- end -}}

{{- if hasKey . "name" -}}
{{-   $name = .name -}}
{{- else -}}
{{-   $name = promptString "name" -}}
{{- end -}}

{{- if hasKey . "bitwarden" -}}
{{-   $bitwarden = .bitwarden -}}
{{- else -}}
{{-   $bitwarden = promptBool "use bitwarden for secrets" -}}
{{- end -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}
    os = {{ .chezmoi.os | quote }}
    arch = {{ .chezmoi.arch | quote }}
    hostname = {{ .chezmoi.hostname | quote }}
    bitwarden = {{ $bitwarden }}
